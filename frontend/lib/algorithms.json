{
  "Quantum Foundations": [
    {
      "id": "bell_state",
      "name": "Bell State",
      "qubits": 2,
      "description": "Prepare an entangled Bell pair and measure both qubits.",
      "gates": [
        { "type": "H", "target": 0 },
        { "type": "CNOT", "control": 0, "target": 1 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 }
      ]
    },
    {
      "id": "ghz_state",
      "name": "GHZ State",
      "qubits": 3,
      "description": "Create a three-qubit GHZ state with chained entanglement.",
      "gates": [
        { "type": "H", "target": 0 },
        { "type": "CNOT", "control": 0, "target": 1 },
        { "type": "CNOT", "control": 1, "target": 2 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 },
        { "type": "M", "target": 2 }
      ]
    },
    {
      "id": "w_state",
      "name": "W State",
      "qubits": 3,
      "description": "Demonstrate distributed excitation across three qubits.",
      "gates": [
        { "type": "RY", "target": 0, "theta": 1.91 },
        { "type": "CNOT", "control": 0, "target": 1 },
        { "type": "RY", "target": 1, "theta": 1.23 },
        { "type": "CNOT", "control": 1, "target": 2 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 },
        { "type": "M", "target": 2 }
      ]
    }
  ],
  "Search Algorithms": [
    {
      "id": "grover_2q",
      "name": "Grover",
      "qubits": 2,
      "description": "A compact Grover search iteration on two qubits.",
      "gates": [
        { "type": "H", "target": 0 },
        { "type": "H", "target": 1 },
        { "type": "CZ", "control": 0, "target": 1 },
        { "type": "H", "target": 0 },
        { "type": "H", "target": 1 },
        { "type": "X", "target": 0 },
        { "type": "X", "target": 1 },
        { "type": "CZ", "control": 0, "target": 1 },
        { "type": "X", "target": 0 },
        { "type": "X", "target": 1 },
        { "type": "H", "target": 0 },
        { "type": "H", "target": 1 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 }
      ]
    },
    {
      "id": "deutsch",
      "name": "Deutsch Algorithm",
      "qubits": 2,
      "description": "Distinguish between balanced and constant oracles.",
      "gates": [
        { "type": "X", "target": 1 },
        { "type": "H", "target": 0 },
        { "type": "H", "target": 1 },
        { "type": "CNOT", "control": 0, "target": 1 },
        { "type": "H", "target": 0 },
        { "type": "M", "target": 0 }
      ]
    },
    {
      "id": "deutsch_jozsa",
      "name": "Deutsch-Jozsa",
      "qubits": 3,
      "description": "A small Deutsch-Jozsa circuit with two input qubits.",
      "gates": [
        { "type": "X", "target": 2 },
        { "type": "H", "target": 0 },
        { "type": "H", "target": 1 },
        { "type": "H", "target": 2 },
        { "type": "CNOT", "control": 0, "target": 2 },
        { "type": "CNOT", "control": 1, "target": 2 },
        { "type": "H", "target": 0 },
        { "type": "H", "target": 1 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 }
      ]
    }
  ],
  "Fourier Algorithms": [
    {
      "id": "qft_3q",
      "name": "Quantum Fourier Transform",
      "qubits": 3,
      "description": "Three-qubit QFT with controlled phase rotations and swap.",
      "gates": [
        { "type": "H", "target": 0 },
        { "type": "CRZ", "control": 1, "target": 0, "theta": 1.5708 },
        { "type": "CRZ", "control": 2, "target": 0, "theta": 0.7854 },
        { "type": "H", "target": 1 },
        { "type": "CRZ", "control": 2, "target": 1, "theta": 1.5708 },
        { "type": "H", "target": 2 },
        { "type": "SWAP", "control": 0, "target": 2 }
      ]
    },
    {
      "id": "qpe_basic",
      "name": "Quantum Phase Estimation",
      "qubits": 3,
      "description": "Estimate a simple phase using two counting qubits.",
      "gates": [
        { "type": "H", "target": 0 },
        { "type": "H", "target": 1 },
        { "type": "CRZ", "control": 0, "target": 2, "theta": 3.1416 },
        { "type": "CRZ", "control": 1, "target": 2, "theta": 6.2832 },
        { "type": "H", "target": 0 },
        { "type": "CRZ", "control": 1, "target": 0, "theta": -1.5708 },
        { "type": "H", "target": 1 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 }
      ]
    }
  ],
  "Variational Algorithms": [
    {
      "id": "vqe_ansatz",
      "name": "VQE Ansatz",
      "qubits": 2,
      "description": "A compact variational ansatz with entanglement and readout.",
      "gates": [
        { "type": "RY", "target": 0, "theta": 0.8 },
        { "type": "RY", "target": 1, "theta": 1.2 },
        { "type": "CNOT", "control": 0, "target": 1 },
        { "type": "RZ", "target": 0, "theta": 0.4 },
        { "type": "RZ", "target": 1, "theta": 0.9 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 }
      ]
    },
    {
      "id": "vqe_ansatz_3q",
      "name": "Layered VQE Ansatz",
      "qubits": 3,
      "description": "Three-qubit variational circuit with chained entanglers.",
      "gates": [
        { "type": "RY", "target": 0, "theta": 0.7 },
        { "type": "RY", "target": 1, "theta": 1.1 },
        { "type": "RY", "target": 2, "theta": 0.5 },
        { "type": "CNOT", "control": 0, "target": 1 },
        { "type": "CNOT", "control": 1, "target": 2 },
        { "type": "RZ", "target": 0, "theta": 0.4 },
        { "type": "RZ", "target": 1, "theta": 0.9 },
        { "type": "RZ", "target": 2, "theta": 0.2 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 },
        { "type": "M", "target": 2 }
      ]
    }
  ],
  "Linear Algebra Algorithms": [
    {
      "id": "hhl_demo",
      "name": "HHL Demo",
      "qubits": 3,
      "description": "Simplified HHL-style phase estimation and readout flow.",
      "gates": [
        { "type": "H", "target": 0 },
        { "type": "H", "target": 1 },
        { "type": "CRZ", "control": 0, "target": 2, "theta": 1.5708 },
        { "type": "CRZ", "control": 1, "target": 2, "theta": 3.1416 },
        { "type": "H", "target": 0 },
        { "type": "CRZ", "control": 1, "target": 0, "theta": -1.5708 },
        { "type": "H", "target": 1 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 }
      ]
    }
  ],
  "Quantum Communication": [
    {
      "id": "teleportation",
      "name": "Quantum Teleportation",
      "qubits": 3,
      "description": "Teleport an unknown state using entanglement and corrections.",
      "gates": [
        { "type": "H", "target": 1 },
        { "type": "CNOT", "control": 1, "target": 2 },
        { "type": "CNOT", "control": 0, "target": 1 },
        { "type": "H", "target": 0 },
        { "type": "CNOT", "control": 1, "target": 2 },
        { "type": "CZ", "control": 0, "target": 2 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 },
        { "type": "M", "target": 2 }
      ]
    },
    {
      "id": "superdense_coding",
      "name": "Superdense Coding",
      "qubits": 2,
      "description": "Encode two classical bits into one transmitted qubit.",
      "gates": [
        { "type": "H", "target": 0 },
        { "type": "CNOT", "control": 0, "target": 1 },
        { "type": "X", "target": 0 },
        { "type": "Z", "target": 0 },
        { "type": "CNOT", "control": 0, "target": 1 },
        { "type": "H", "target": 0 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 }
      ]
    }
  ],
  "Post-Quantum Cryptography": [
    {
      "id": "kyber_demo",
      "name": "Kyber Concept Demo",
      "qubits": 2,
      "description": "Circuit sketch inspired by lattice-based post-quantum primitives.",
      "gates": [
        { "type": "H", "target": 0 },
        { "type": "H", "target": 1 },
        { "type": "CNOT", "control": 0, "target": 1 },
        { "type": "RZ", "target": 0, "theta": 0.7 },
        { "type": "RZ", "target": 1, "theta": 1.1 },
        { "type": "RY", "target": 0, "theta": 0.6 },
        { "type": "RY", "target": 1, "theta": 0.9 },
        { "type": "CZ", "control": 0, "target": 1 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 }
      ]
    },
    {
      "id": "dilithium_demo",
      "name": "Dilithium Concept Demo",
      "qubits": 2,
      "description": "Circuit sketch echoing structured lattice signing workflows.",
      "gates": [
        { "type": "H", "target": 0 },
        { "type": "H", "target": 1 },
        { "type": "RY", "target": 0, "theta": 0.9 },
        { "type": "RY", "target": 1, "theta": 0.4 },
        { "type": "CNOT", "control": 0, "target": 1 },
        { "type": "RZ", "target": 0, "theta": 1.2 },
        { "type": "RZ", "target": 1, "theta": 0.7 },
        { "type": "CZ", "control": 0, "target": 1 },
        { "type": "M", "target": 0 },
        { "type": "M", "target": 1 }
      ]
    }
  ]
}
